import java.util.Scanner;
class Practice 
{
	static Scanner sc = new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.print("Enter a number : ");
		int n = sc.nextInt();
		for(int i=0;i<n;i++)
		{
			for(int j=0;j<n;j++)
			{
				if((i==j && i>=n/2)||(i+j==n-1 && i>=n/2))	System.out.print("* ");
				else	System.out.print("  ");
			}
			System.out.println();
		}
	}
}
