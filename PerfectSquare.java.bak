import java.util.Scanner;
class PerfectSquare 
{
	static Scanner sc = new Scanner(System.in);
	
	public static int square(int n)
	{
		for(int i = 2; i <= n; i++)
		{
			if(i * i == n) return i;
			if(i * i > n) return i;
		}
		return n;
	}
	
	public static void main(String[] args) 
	{
		System.out.print("Enter a number : ");
		int n = sc.nextInt();
		System.out.println(square(n));
	}
}
