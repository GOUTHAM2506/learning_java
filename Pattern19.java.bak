//Weird Pattern
import java.util.Scanner;
class Pattern19
{
	static Scanner sc = new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.print("Enter a range : ");
		int n = sc.nextInt();
		for (int i=0;i<n;i++)
		{
			//1
			for (int j=0;j<n;j++)
			{
				if((j==0 && i<=n/2) || (j==n-1 && i>=n/2) || (i==0 && j<=n/2) || (i==n-1 && j>=n/2) || i==j || i+j==n-1)	System.out.print("* ");
				else	System.out.print("  ");
			}
			System.out.print("   ");
			//2
			for (int j=0;j<n;j++)
			{
				if((i==0 && j<=n/2) || (j==0 && i<=n/2) || (i==j && i>=n/2))	System.out.print("* ");
				else	System.out.print("  ");
			}
			System.out.print("   ");
			//3
			for (int j=0;j<n;j++)
			{
				if((i==0 && j>=n/2) || (j==n-1 && i<=n/2) || (i+j==n-1 && i>=n/2))	System.out.print("* ");
				else	System.out.print("  ");
			}
			System.out.print("   ");
			System.out.println();
		}
	}
}