import java.util.Scanner;
class Login
{
	static Scanner sc = new Scanner(System.in);
	public static void main(String[] args) throws Exception
	{
		System.out.println("\tWelcome to my Application");
		long regphNo = 9876543210L;
		System.out.print("Enter your Phone Number : ");
		long userphNo = sc.nextLong();
		System.out.println("\tProcessing.....");
		Thread.sleep(2000);
		if(regphNo == userphNo)
		{
			int genOtp = (int)(Math.random()*9000)+1000;
			System.out.println("\tGenerating Otp.....");
			Thread.sleep(1000);
			System.out.println("Your OTP is : "+genOtp+". Don't share to anyone");
			System.out.print("Enter Otp : ");
			int userOtp = sc.nextInt();
			System.out.println("\tProcessing.....");
			Thread.sleep(2000);
			if(genOtp == userOtp)
			{
				System.out.println("\tLogin Done Successfully");
			}
			else
			{
				System.out.println("\tInvalid Credentials");
			}
		}
		else
		{
			System.out.println("\tInvalid Credentials");
		}
	}
}
