//Arrows
import java.util.Scanner;
class Arrows1
{
	static Scanner sc = new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.print("Enter your range : ");
		int n = sc.nextInt();
		for(int i=0;i<n;i++)
		{
			//1
			for(int j=0;j<n;j++)
			{
				if(j==0 || i==n-1 || i+j==n-1) System.out.print("* ");
				else System.out.print("  ");
			}
			System.out.print(" ");
			//2
			for(int j=0;j<n;j++)
			{
				if(i==0 || j==0 || i==j) System.out.print("* ");
				else System.out.print("  ");
			}
			System.out.print(" ");
			//3
			for(int j=0;j<n;j++)
			{
				if(i==j || i==n-1 || j==n-1) System.out.print("* ");
				else System.out.print("  ");
			}
			System.out.print(" ");
			//4
			for(int j=0;j<n;j++)
			{
				if(i==0 || j==n-1 || i+j==n-1) System.out.print("* ");
				else System.out.print("  ");
			}
			System.out.print(" ");
			System.out.println();
		}
	}
}
