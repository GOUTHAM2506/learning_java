//Jesus
import java.util.Scanner;
class Jesus
{
	static Scanner sc = new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.print("Enter a range : ");
		int n = sc.nextInt();
		for (int i=0;i<n-1;i++)
		{
			for (int j=0;j<n;j++)
			{
				if((i==1 && (j>=1 && j<=n-2))|| j==n/2 )	System.out.print("* ");
				else	System.out.print("  ");
			}
			System.out.println();
		}
	}
}