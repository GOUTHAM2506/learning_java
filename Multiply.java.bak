import java.util.Scanner;
class Multiply
{
	static Scanner sc = new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.print("Enter a number : ");
		int a = sc.nextInt();
		int mul = 0;
		for(int i=1;i<=a;i++)
		{
			mul*=i;
		}
		System.out.println("Product from 1 to "+a+" is : "+mul);
	}
}
